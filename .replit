modules = ["nodejs-22"]

run = "npm run web -- --host lan"
entrypoint = "package.json"
hidden = [".expo", "dist", "node_modules"]

[deployment]
build = ["sh", "-c", "npm ci && npm run export:web"]
run = ["sh", "-c", "npx expo serve --port 8080"]

[[ports]]
localPort = 8081
externalPort = 80

[agent]
expertMode = true
