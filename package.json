{
  "name": "nexus-ai",
  "version": "3.0.0",
  "private": true,
  "description": "Nexus AI — Personal Mission OS",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "export:web": "expo export --platform web --max-workers 2",
    "serve:web": "expo serve",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "doctor": "expo-doctor",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "release:check": "node scripts/release-check.mjs",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run security:secrets",
    "native:check": "node scripts/detect-native-changes.mjs"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.39",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.4",
    "expo-asset": "~57.0.0",
    "expo-audio": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-haptics": "~57.0.1",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-navigation-bar": "~57.0.1",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "expo-doctor": "1.20.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.13 <23"
  },
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "uuid": "11.1.1"
    }
  }
}
