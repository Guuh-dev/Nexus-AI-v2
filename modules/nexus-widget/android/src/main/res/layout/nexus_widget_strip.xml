<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/nexus_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:minWidth="110dp"
  android:minHeight="40dp"
  android:paddingLeft="8dp"
  android:paddingTop="3dp"
  android:paddingRight="8dp"
  android:paddingBottom="3dp"
  android:background="@drawable/nexus_widget_background">
  <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical">
    <LinearLayout android:id="@+id/nexus_widget_mascot_stage" android:layout_width="58dp" android:layout_height="match_parent" android:layout_marginEnd="8dp" android:orientation="horizontal" android:gravity="center" android:visibility="gone">
      <ImageView android:id="@+id/nexus_widget_mascot" android:layout_width="52dp" android:layout_height="52dp" android:layout_gravity="center" android:adjustViewBounds="true" android:scaleType="fitCenter" android:src="@drawable/ic_nexus_mascot" android:contentDescription="@string/nexus_widget_mascot_description" />
    </LinearLayout>
    <TextView android:id="@+id/nexus_widget_accessory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#F7F7F8" android:textSize="10sp" android:visibility="gone" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
      <TextView android:id="@+id/nexus_widget_brand" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="→ PRÓXIMA AÇÃO" android:textColor="#A78BFA" android:textSize="7sp" android:textStyle="bold" android:maxLines="1" />
      <TextView android:id="@+id/nexus_widget_mission" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Revisar a missão de hoje" android:textColor="#F7F7F8" android:textSize="10sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" />
      <TextView android:id="@+id/nexus_widget_feature_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#A78BFA" android:textSize="9sp" android:textStyle="bold" android:maxLines="1" android:visibility="gone" />
      <TextView android:id="@+id/nexus_widget_feature_body" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#F7F7F8" android:textSize="11sp" android:maxLines="1" android:ellipsize="end" android:visibility="gone" />
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
        <ProgressBar android:id="@+id/nexus_widget_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:progressTint="#8B5CF6" android:progressBackgroundTint="#34343F" android:visibility="gone" />
        <TextView android:id="@+id/nexus_widget_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="●●●○○○○○  2/5" android:textColor="#A1A1AA" android:textSize="7sp" />
      </LinearLayout>
    </LinearLayout>
    <TextView android:id="@+id/nexus_widget_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="♨ 0" android:textColor="#FBBF24" android:textSize="11sp" android:textStyle="bold" android:visibility="gone" />
  </LinearLayout>
  <LinearLayout android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" android:orientation="vertical">
    <TextView android:id="@+id/nexus_widget_page" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:id="@+id/nexus_widget_task_1" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_1" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_1" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_2" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_2" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_2" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_3" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_3" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_3" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_4" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_4" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_4" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_5" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_5" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_5" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <TextView android:id="@+id/nexus_widget_metrics" android:layout_width="wrap_content" android:layout_height="wrap_content"/><TextView android:id="@+id/nexus_widget_capture" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
  </LinearLayout>
</FrameLayout>
