<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/nexus_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:minWidth="250dp"
  android:minHeight="250dp"
  android:orientation="vertical"
  android:gravity="center_vertical"
  android:padding="12dp"
  android:background="@drawable/nexus_widget_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">
    <LinearLayout
      android:id="@+id/nexus_widget_mascot_stage"
      android:layout_width="48dp"
      android:layout_height="42dp"
      android:layout_marginEnd="6dp"
      android:orientation="horizontal"
      android:gravity="center">
      <ImageView
        android:id="@+id/nexus_widget_mascot"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:contentDescription="@string/nexus_widget_mascot_description"
        android:src="@drawable/ic_nexus_mascot" />
    </LinearLayout>
    <TextView
      android:id="@+id/nexus_widget_accessory"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginEnd="7dp"
      android:text=""
      android:textColor="#F7F7F8"
      android:textSize="11sp"
      android:textStyle="bold"
      android:visibility="gone" />
    <TextView
      android:id="@+id/nexus_widget_brand"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="NEXUS COMMAND"
      android:textColor="#A78BFA"
      android:textSize="10sp"
      android:textStyle="bold"
      android:letterSpacing="0.12" />
    <TextView
      android:id="@+id/nexus_widget_streak"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="♨ 0"
      android:textColor="#FBBF24"
      android:textSize="12sp"
      android:textStyle="bold"
      android:visibility="gone" />
    <TextView
      android:id="@+id/nexus_widget_page"
      android:layout_width="34dp"
      android:layout_height="34dp"
      android:layout_marginStart="6dp"
      android:gravity="center"
      android:text="↻"
      android:textColor="#A78BFA"
      android:textSize="18sp"
      android:textStyle="bold"
      android:background="@drawable/nexus_widget_action"
      android:visibility="gone" />
  </LinearLayout>

  <TextView
    android:id="@+id/nexus_widget_mission"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="Missão de hoje"
    android:textColor="#F7F7F8"
    android:textSize="16sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/nexus_widget_feature_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:text="COMPANION • HAPPY"
    android:textColor="#A78BFA"
    android:textSize="10sp"
    android:textStyle="bold"
    android:letterSpacing="0.08" />

  <TextView
    android:id="@+id/nexus_widget_feature_body"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:ellipsize="end"
    android:maxLines="2"
    android:text="Nexus ativo."
    android:textColor="#F7F7F8"
    android:textSize="11sp"
    android:lineSpacingExtra="1dp" />

  <LinearLayout android:id="@+id/nexus_widget_task_1" style="@style/NexusWidgetTaskRow">
    <TextView android:id="@+id/nexus_widget_check_1" style="@style/NexusWidgetCheck" />
    <TextView android:id="@+id/nexus_widget_task_title_1" style="@style/NexusWidgetTaskTitle" android:text="Definir a próxima ação" />
  </LinearLayout>
  <LinearLayout android:id="@+id/nexus_widget_task_2" style="@style/NexusWidgetTaskRow">
    <TextView android:id="@+id/nexus_widget_check_2" style="@style/NexusWidgetCheck" />
    <TextView android:id="@+id/nexus_widget_task_title_2" style="@style/NexusWidgetTaskTitle" android:text="Executar o bloco principal" />
  </LinearLayout>
  <LinearLayout android:id="@+id/nexus_widget_task_3" style="@style/NexusWidgetTaskRow">
    <TextView android:id="@+id/nexus_widget_check_3" style="@style/NexusWidgetCheck" />
    <TextView android:id="@+id/nexus_widget_task_title_3" style="@style/NexusWidgetTaskTitle" android:text="Revisar o progresso" />
  </LinearLayout>
  <LinearLayout android:id="@+id/nexus_widget_task_4" style="@style/NexusWidgetTaskRow">
    <TextView android:id="@+id/nexus_widget_check_4" style="@style/NexusWidgetCheck" />
    <TextView android:id="@+id/nexus_widget_task_title_4" style="@style/NexusWidgetTaskTitle" android:text="Fechar o ciclo de hoje" />
  </LinearLayout>

  <TextView
    android:id="@+id/nexus_widget_metrics"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:text="25m foco • 2/5 tarefas"
    android:textColor="#A1A1AA"
    android:textSize="10sp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">
    <ProgressBar
      android:id="@+id/nexus_widget_progress"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="0dp"
      android:layout_height="5dp"
      android:layout_weight="1"
      android:progressTint="#8B5CF6"
      android:progressBackgroundTint="#34343F"
      android:visibility="gone" />
    <TextView
      android:id="@+id/nexus_widget_progress_text"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="10dp"
      android:text="●●●○○○○○  2/5"
      android:textColor="#A1A1AA"
      android:textSize="10sp" />
  </LinearLayout>

  <TextView
    android:id="@+id/nexus_widget_capture"
    android:layout_width="match_parent"
    android:layout_height="32dp"
    android:layout_marginTop="7dp"
    android:gravity="center"
    android:text="＋ Capturar rápido"
    android:textColor="#F7F7F8"
    android:textSize="11sp"
    android:textStyle="bold"
    android:background="@drawable/nexus_widget_action"
    android:visibility="gone" />

  <LinearLayout android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" android:orientation="vertical">
    <LinearLayout android:id="@+id/nexus_widget_task_5" style="@style/NexusWidgetTaskRow">
      <TextView android:id="@+id/nexus_widget_check_5" style="@style/NexusWidgetCheck" />
      <TextView android:id="@+id/nexus_widget_task_title_5" style="@style/NexusWidgetTaskTitle" />
    </LinearLayout>
  </LinearLayout>
</LinearLayout>
