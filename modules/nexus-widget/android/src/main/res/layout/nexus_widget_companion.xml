<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/nexus_widget_root" android:layout_width="match_parent" android:layout_height="match_parent"
  android:minWidth="110dp" android:minHeight="110dp" android:padding="12dp" android:background="@drawable/nexus_widget_background_transparent">
  <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center">
    <LinearLayout android:id="@+id/nexus_widget_mascot_stage" android:layout_width="match_parent" android:layout_height="70dp" android:orientation="horizontal" android:gravity="center">
      <ImageView android:id="@+id/nexus_widget_mascot" android:layout_width="62dp" android:layout_height="62dp" android:layout_gravity="center" android:src="@drawable/ic_nexus_mascot" android:contentDescription="@string/nexus_widget_mascot_description" />
      <TextView android:id="@+id/nexus_widget_accessory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:textColor="#F7F7F8" android:textSize="13sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
      <ImageView android:id="@+id/nexus_widget_professor" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_nexus_atlas" android:visibility="gone" android:contentDescription="@string/nexus_widget_professor_description" />
      <TextView android:id="@+id/nexus_widget_brand" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEXUS COMPANION" android:textColor="#A78BFA" android:textSize="9sp" android:textStyle="bold" />
      <TextView android:id="@+id/nexus_widget_streak" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="♨ 0" android:textColor="#FBBF24" android:textSize="10sp" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:id="@+id/nexus_widget_feature_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:textColor="#A78BFA" android:textSize="9sp" android:textStyle="bold" android:maxLines="1" />
    <TextView android:id="@+id/nexus_widget_feature_body" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="center" android:textColor="#F7F7F8" android:textSize="11sp" android:maxLines="3" android:ellipsize="end" />
  </LinearLayout>
  <LinearLayout android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" android:orientation="vertical">
    <TextView android:id="@+id/nexus_widget_page" android:layout_width="wrap_content" android:layout_height="wrap_content"/><TextView android:id="@+id/nexus_widget_mission" android:layout_width="wrap_content" android:layout_height="wrap_content"/><TextView android:id="@+id/nexus_widget_learning" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <LinearLayout android:id="@+id/nexus_widget_task_1" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_1" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_1" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_2" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_2" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_2" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_3" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_3" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_3" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_4" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_4" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_4" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <LinearLayout android:id="@+id/nexus_widget_task_5" style="@style/NexusWidgetTaskRow"><TextView android:id="@+id/nexus_widget_check_5" style="@style/NexusWidgetCheck"/><TextView android:id="@+id/nexus_widget_task_title_5" style="@style/NexusWidgetTaskTitle"/></LinearLayout>
    <TextView android:id="@+id/nexus_widget_metrics" android:layout_width="wrap_content" android:layout_height="wrap_content"/><ProgressBar android:id="@+id/nexus_widget_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="1dp" android:layout_height="1dp"/><TextView android:id="@+id/nexus_widget_progress_text" android:layout_width="wrap_content" android:layout_height="wrap_content"/><TextView android:id="@+id/nexus_widget_capture" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
  </LinearLayout>
</FrameLayout>
